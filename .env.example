# ===== 企业微信配置 =====
# 从企业微信后台「我的企业」→「企业信息」获取
WECHAT_CORPID=你的企业ID
# 从企业微信后台「应用管理」→「你的应用」获取
WECHAT_AGENTID=1000002
WECHAT_SECRET=你的应用Secret
WECHAT_TOKEN=你的Token
WECHAT_ENCODING_AES_KEY=你的EncodingAESKey

# ===== AI API Key =====
# AIHubMix: https://aihubmix.com 注册获取
AI_API_KEY=sk-your-aihubmix-key

# DeepSeek: https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ===== 服务器部署说明 =====
# 将 .env.example 复制为 .env 并填入真实值
# 然后在服务器上 source .env 或用 systemd 配置 EnvironmentFile
# 或直接在 /etc/environment 中设置
